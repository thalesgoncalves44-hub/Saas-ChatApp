{
  "name": "@zappai/print-agent",
  "version": "1.0.0",
  "description": "ZappAI thermal printer agent for ESC/POS printers",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "pkg:win": "pkg dist/index.js --targets node18-win-x64 --output bin/zappai-print-agent-win.exe",
    "pkg:mac": "pkg dist/index.js --targets node18-macos-x64 --output bin/zappai-print-agent-mac",
    "pkg:linux": "pkg dist/index.js --targets node18-linux-x64 --output bin/zappai-print-agent-linux"
  },
  "dependencies": {
    "escpos": "^3.0.0-alpha.4",
    "escpos-network": "^3.0.0-alpha.2",
    "escpos-usb": "^3.0.0-alpha.4",
    "socket.io-client": "^4.7.0",
    "qrcode": "^1.5.3",
    "node-thermal-printer": "^4.4.3",
    "serialport": "^12.0.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.10"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.5",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  },
  "pkg": {
    "assets": ["dist/**/*"],
    "targets": ["node18-win-x64", "node18-macos-x64", "node18-linux-x64"]
  }
}
